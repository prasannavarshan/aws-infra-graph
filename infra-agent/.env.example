# =============================================================================
# infra-agent configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---

# LiteLLM platform API key for LLM inference
LITELLM_API_KEY=

# URL of the aws-infra-graph MCP server
MCP_SERVER_URL=http://localhost:8000

# --- Optional ---

# LiteLLM proxy/gateway base URL (required when using a LiteLLM proxy)
# LITELLM_BASE_URL=https://your-litellm-proxy.example.com

# LiteLLM model identifier (default: gpt-4o)
# LITELLM_MODEL=gpt-4o

# Session idle timeout in minutes (default: 60)
# SESSION_TTL_MINUTES=60

# Logging level (default: INFO)
# LOG_LEVEL=INFO

# Path to the system prompt markdown file (default: system_prompt.md)
# SYSTEM_PROMPT_PATH=system_prompt.md

# --- Authentication (OIDC/SSO) ---

# OIDC issuer URL for token validation
# OIDC_ISSUER_URL=

# OIDC audience / client ID
# OIDC_AUDIENCE=
