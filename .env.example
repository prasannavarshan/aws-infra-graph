# =============================================================================
# AWS Infrastructure Graph — Environment Configuration
# =============================================================================
# Copy this file to .env and edit with your values:
#   cp .env.example .env
# =============================================================================

# --- AWS Configuration ---

# MODE 1: Single-account (default)
# Uses your current AWS CLI credentials (~/.aws/credentials or env vars).
# Leave CROSS_ACCOUNT_ROLE_NAME empty. Account ID is auto-detected.
# Just set the regions you want to crawl.

# MODE 2: Multi-account (AWS Organizations)
# Set CROSS_ACCOUNT_ROLE_NAME to the IAM role that exists in all child accounts.
# When ACCOUNT_IDS is empty AND CROSS_ACCOUNT_ROLE_NAME is set, accounts are
# auto-discovered from the Organizations API (only ACTIVE accounts).
# Optionally set ORG_ROLE_ARN for the management account role.

# AWS CLI profile name (from ~/.aws/config). Empty = default credential chain.
# Example: AWS_PROFILE=Master
AWS_PROFILE=
# Role ARN in the management account (multi-account only)
AWS_ORG_ROLE_ARN=
# Role name to assume in each child account (empty = single-account mode)
# Example: AWS_CROSS_ACCOUNT_ROLE_NAME=SRETransientRole
AWS_CROSS_ACCOUNT_ROLE_NAME=
# Default region for global AWS API calls
AWS_DEFAULT_REGION=us-east-1
# JSON array of regions to crawl
AWS_REGIONS=["us-east-1"]
# JSON array of account IDs (empty = auto-discover from Organizations)
AWS_ACCOUNT_IDS=

# --- Neo4j Configuration ---

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- MCP Server Configuration ---

# Transport: "stdio" for Claude Code local, "sse" for remote access
TRANSPORT=stdio
HOST=0.0.0.0
PORT=8050

# Bearer token for HTTP transport authentication.
# If empty and using HTTP transport, an ephemeral token is generated on startup.
# Generate a persistent token: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=
